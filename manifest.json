{
  "manifest_version": 3,
  "name": "Quick Group Posting",
  "version": "1.0.0",
  "description": "Quickly post templates to Facebook Groups from the joined groups page.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://web.facebook.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Quick Group Posting",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/groups/",
        "https://www.facebook.com/groups/*",
        "https://web.facebook.com/groups/",
        "https://web.facebook.com/groups/*"
      ],
      "js": [
        "shared/storage.js",
        "content/injectButtons.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/helpers.js",
        "content/injectGraphQL.js"
      ],
      "matches": [
        "https://www.facebook.com/*",
        "https://web.facebook.com/*"
      ]
    }
  ]
}